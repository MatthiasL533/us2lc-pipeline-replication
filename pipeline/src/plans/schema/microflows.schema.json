{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "microflows.schema.json",
  "title": "Microflow section",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "clearExisting": { "type": "boolean" },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name"],
        "properties": {
          "ref": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["type"],
              "properties": {
                "type": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "items": { "type": "array" }
  }
}
