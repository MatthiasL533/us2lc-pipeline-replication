  "microflows": {
    "specs": [
      {
        "name": "CreateSubscription",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "membershipType",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.MembershipType"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Subscription",
            "outputVariableName": "Subscription_New"
          },
          {
            "type": "commitObject",
            "variableName": "Subscription_New"
          }
        ]
      },
      {
        "name": "UpdateNoShowCount",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Customer",
            "variable": "customerObject",
            "outputVariableName": "Customer_Object"
          }
        ]
      },
      {
        "name": "SendNotification",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "message",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "NotificationPreference",
            "variable": "notificationPreference",
            "outputVariableName": "NotificationPreference_Object"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "$message"
              }
            ],
            "falseActions": [],
            "conditionExpression": "= $NotificationPreference_Object/notificationMethod = 'email'"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckSubscriptionStatus",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "variable": "subscription",
            "outputVariableName": "Subscription_Object"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "Your subscription has expired."
              }
            ],
            "falseActions": [],
            "conditionExpression": "= $Subscription_Object/endDate < now()"
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
