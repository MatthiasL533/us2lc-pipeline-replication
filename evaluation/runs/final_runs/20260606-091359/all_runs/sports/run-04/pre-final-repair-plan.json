  "microflows": {
    "specs": [
      {
        "name": "IssueFineToNoShowCustomer",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "noShowCount",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "decision",
            "caption": "Check if no show count is greater than 2",
            "trueAction": {
              "type": "createObject",
              "entity": "Fine",
              "attributes": {
                "Amount": "= $noShowCount * 10",
                "fineDate": "= [%CurrentDateTime%]"
              }
            },
            "falseAction": null,
            "conditionExpression": "$noShowCount > 2",
            "trueActions": [],
            "falseActions": []
          },
          {
            "type": "commitObject",
            "variableName": "customer"
          }
        ]
      },
      {
        "name": "SendNotificationToCustomer",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "notificationMessage",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Notification",
            "outputVariableName": "Notification_New"
          },
          {
            "type": "changeObject",
            "targetVariableName": "Notification_New",
            "changes": [
              {
                "attributeRef": "Message",
                "valueExpression": "$notificationMessage"
              }
            ]
          },
          {
            "type": "commitObject",
            "variableName": "customer"
          }
        ]
      },
      {
        "name": "UpdateCustomerMembershipStatus",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "membershipStatus",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "commitObject",
            "variableName": "customer"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckCustomerSubscription",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "constraint": "= $customer/Subscription",
            "variable": "subscription",
            "outputVariableName": "Subscription_Object"
          },
          {
            "type": "decision",
            "caption": "Check if subscription is active",
            "trueAction": {
              "type": "returnValue",
              "value": true
            },
            "falseAction": {
              "type": "returnValue",
              "value": false
            },
            "conditionExpression": "$Subscription_Object/endDate > [%CurrentDateTime%]",
            "trueActions": [],
            "falseActions": []
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
