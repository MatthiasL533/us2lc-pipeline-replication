            "type": "retrieveObject",
            "entity": "NotificationPreference",
            "variableName": "notificationPreference",
            "constraints": [
              {
                "member": "Customer",
                "operator": "equal to",
                "value": "$customer"
              }
            ],
            "outputVariableName": "notificationPreference"
          },
          {
            "type": "decision",
            "trueActions": [
