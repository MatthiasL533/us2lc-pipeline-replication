  "microflows": {
    "specs": [
      {
        "name": "IssueFineToCustomer",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "fineAmount",
            "type": "Decimal"
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Fine",
            "variableName": "newFine",
            "outputVariableName": "newFine"
          },
          {
            "type": "commitObject",
            "variableName": "newFine"
          },
          {
            "type": "commitObject",
            "variableName": "customer"
          }
        ]
      },
      {
        "name": "SendNotificationToCustomer",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          },
          {
            "name": "message",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Notification",
            "variableName": "newNotification",
            "outputVariableName": "newNotification"
          },
          {
            "type": "commitObject",
            "variableName": "newNotification"
          },
          {
            "type": "showMessage",
            "message": "$message"
          }
        ]
      },
      {
        "name": "CheckCustomerSubscription",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "variableName": "subscription",
            "constraints": [
              {
                "member": "Customer",
                "operator": "equal to",
                "value": "$customer"
              }
            ],
            "outputVariableName": "subscription"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "Customer has a subscription"
              }
            ],
            "falseActions": [
              {
                "type": "showMessage",
                "message": "Customer does not have a subscription"
              }
            ],
            "conditionExpression": "$subscription != null"
          }
        ]
      },
      {
        "name": "UpdateNoShowCountForCustomer",
        "parameters": [
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "commitObject",
            "variableName": "customer"
          }
        ]
      },
      {
        "name": "CancelLessonForCustomer",
        "parameters": [
          {
            "name": "lesson",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Lesson"
            }
          },
          {
            "name": "customer",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Customer"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "BookingCancellation",
            "variableName": "bookingCancellation",
            "constraints": [
              {
                "member": "Lesson",
                "operator": "equal to",
                "value": "$lesson"
              },
              {
                "member": "Customer",
                "operator": "equal to",
                "value": "$customer"
              }
            ],
            "outputVariableName": "bookingCancellation"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "Lesson is already canceled for customer"
              }
            ],
            "falseActions": [
              {
                "type": "createObject",
                "entity": "BookingCancellation",
                "variableName": "newBookingCancellation",
                "outputVariableName": "newBookingCancellation"
              },
              {
                "type": "commitObject",
                "variableName": "newBookingCancellation"
              },
              {
                "type": "showMessage",
                "message": "Lesson has been canceled for customer"
              }
            ],
            "conditionExpression": "$bookingCancellation != null"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckCustomerNotificationPreference",
        "parameters": [
