  "verification": {
    "failOnMissing": true
  },
  "microflows": {
    "specs": [
      {
        "name": "CreateNewOrderNotification",
        "parameters": [
          {
            "name": "order",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Order"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "NewOrderNotification",
            "variableName": "newOrderNotification",
            "outputVariableName": "newOrderNotification"
          },
          {
            "type": "commitObject",
            "variableName": "newOrderNotification"
          },
          {
            "type": "showMessage",
            "message": "New order notification created"
          }
        ]
      },
      {
        "name": "UpdateOrderStatus",
        "parameters": [
          {
            "name": "order",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Order"
            }
          },
          {
            "name": "newStatus",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "commitObject",
            "variableName": "order"
          },
          {
            "type": "showMessage",
            "message": "Order status updated to $newStatus"
          }
        ]
      },
      {
        "name": "SendOrderChangeNotification",
        "parameters": [
          {
            "name": "order",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Order"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "OrderChangeNotification",
            "variableName": "orderChangeNotification",
            "outputVariableName": "orderChangeNotification"
          },
          {
            "type": "commitObject",
            "variableName": "orderChangeNotification"
          },
          {
            "type": "showMessage",
            "message": "Order change notification sent"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "GetOrderProducts",
        "parameters": [
          {
            "name": "order",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Order"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "Product",
            "variableName": "products",
            "constraints": [
              {
                "member": "Order_Product",
                "operator": "equals",
                "value": "$order"
              }
            ],
            "outputVariableName": "products"
          },
          {
            "type": "returnValue",
            "value": "products"
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
