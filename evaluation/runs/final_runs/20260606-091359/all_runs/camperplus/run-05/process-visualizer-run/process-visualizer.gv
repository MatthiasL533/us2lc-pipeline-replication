digraph process_visualizer {
  t0 [label="camp administrator: add campers"];
  t1 [label="camp administrator: suspend a camper who had behavioral problems"];
  t2 [label="camp administrator: store camper's immediate parent/guardian's information, so that i can easily call to notify camper's immediate parent/guardian's in case a grossly unacceptable behavior"];
  t3 [label="camp administrator: add parents"];
  t4 [label="camp administrator: modify the information of added parents"];
  t5 [label="parent: delete parents from the database"];
  t6 [label="parent: message my camper counselors"];
  t7 [label="camp worker: see which campers i am in charge of and where"];
  t8 [label="camp counselor: take attendance of my assigned kids"];
}
