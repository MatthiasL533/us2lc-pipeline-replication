{
  "pages": {
    "specs": [
      {
        "name": "home",
        "layout": "Blank",
        "widgets": [
          {
            "type": "Text",
            "text": "Welcome to the Camp Management System"
          },
          {
            "type": "Button",
            "caption": "Manage Campers",
            "onClick": {
              "type": "Navigation",
              "page": "camperOverview"
            }
          },
          {
            "type": "Button",
            "caption": "Manage Parents",
            "onClick": {
              "type": "Navigation",
              "page": "parentOverview"
            }
          },
          {
            "type": "Button",
            "caption": "Manage Groups",
            "onClick": {
              "type": "Navigation",
              "page": "groupOverview"
            }
          },
          {
            "type": "Button",
            "caption": "Manage Events",
            "onClick": {
              "type": "Navigation",
              "page": "eventOverview"
            }
          }
        ],
        "content": []
      },
      {
        "name": "camperOverview",
        "layout": "Table",
        "entity": "Camper",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "Name"
              },
              {
                "attribute": "EmergencyContactInfo"
              }
            ],
            "dataSource": "camperDataSource"
          },
          {
            "type": "Button",
            "caption": "New Camper",
            "onClick": {
              "type": "Navigation",
              "page": "newCamper"
            }
          }
        ],
        "content": []
      },
      {
        "name": "parentOverview",
        "layout": "Table",
        "entity": "Parent",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "Name"
              },
              {
                "attribute": "Email"
              }
            ],
            "dataSource": "parentDataSource"
          },
          {
            "type": "Button",
            "caption": "New Parent",
            "onClick": {
              "type": "Navigation",
              "page": "newParent"
            }
          }
        ],
        "content": []
      },
      {
        "name": "groupOverview",
        "layout": "Table",
        "entity": "Group",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "GroupName"
              }
            ],
            "dataSource": "groupDataSource"
          },
          {
            "type": "Button",
            "caption": "New Group",
            "onClick": {
              "type": "Navigation",
              "page": "newGroup"
            }
          }
        ],
        "content": []
      },
      {
        "name": "eventOverview",
        "layout": "Table",
        "entity": "Event",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "EventName"
              },
              {
                "attribute": "Schedule"
              }
            ],
            "dataSource": "eventDataSource"
          },
          {
            "type": "Button",
            "caption": "New Event",
            "onClick": {
              "type": "Navigation",
              "page": "newEvent"
            }
          }
        ],
        "content": []
      },
      {
        "name": "newCamper",
        "layout": "FormHorizontal",
        "entity": "Camper",
        "widgets": [
          {
            "type": "TextInput",
            "attribute": "Name"
          },
          {
            "type": "TextInput",
            "attribute": "EmergencyContactInfo"
          }
        ],
        "content": []
      },
      {
        "name": "newParent",
        "layout": "FormHorizontal",
        "entity": "Parent",
        "widgets": [
          {
            "type": "TextInput",
            "attribute": "Name"
          },
          {
            "type": "TextInput",
            "attribute": "Email"
          }
        ],
        "content": []
      },
      {
        "name": "newGroup",
        "layout": "FormHorizontal",
        "entity": "Group",
        "widgets": [
          {
            "type": "TextInput",
            "attribute": "GroupName"
          }
        ],
        "content": []
      },
      {
        "name": "newEvent",
        "layout": "FormHorizontal",
        "entity": "Event",
        "widgets": [
          {
            "type": "TextInput",
            "attribute": "EventName"
          },
          {
            "type": "DateTimeInput",
            "attribute": "Schedule"
          }
        ],
        "content": []
      }
    ]
  },
  "app": {
    "navigation": {
      "home": {
        "pages": [
          "camperOverview",
          "parentOverview",
          "groupOverview",
          "eventOverview"
        ]
      },
      "camperOverview": {
        "pages": [
          "newCamper"
        ]
      },
      "parentOverview": {
        "pages": [
          "newParent"
        ]
      },
      "groupOverview": {
        "pages": [
          "newGroup"
        ]
      },
      "eventOverview": {
        "pages": [
          "newEvent"
        ]
      }
    }
  }
}