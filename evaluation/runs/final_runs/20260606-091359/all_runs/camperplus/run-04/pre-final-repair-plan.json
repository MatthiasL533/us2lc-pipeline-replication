  "microflows": {
    "specs": [
      {
        "name": "CreateNametagForCamper",
        "parameters": [
          {
            "name": "camperId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Camper",
            "variableName": "camper",
            "outputVariableName": "camper"
          },
          {
            "type": "createObject",
            "entity": "Nametag",
            "variableName": "nametag",
            "outputVariableName": "nametag"
          },
          {
            "type": "commitObject",
            "variableName": "nametag"
          }
        ]
      },
      {
        "name": "SuspendCamper",
        "parameters": [
          {
            "name": "camperId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Camper",
            "variableName": "camper",
            "outputVariableName": "camper"
          },
          {
            "type": "commitObject",
            "variableName": "camper"
          }
        ]
      },
      {
        "name": "SendReminderToParent",
        "parameters": [
          {
            "name": "parentId",
            "type": "Integer"
          },
          {
            "name": "reminderMessage",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Parent",
            "variableName": "parent",
            "outputVariableName": "parent"
          },
          {
            "type": "showMessage",
            "message": "$reminderMessage",
            "title": "Reminder for $parent.Name"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckCamperAttendance",
        "parameters": [
          {
            "name": "camperId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Camper",
            "variableName": "camper",
            "outputVariableName": "camper"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "Camper $camper.Name is present."
              }
            ],
            "falseActions": [
              {
                "type": "showMessage",
                "message": "Camper $camper.Name is absent."
              }
            ],
            "conditionExpression": "$camper.AttendanceStatus = true"
          }
        ]
      }
    ]
  }
}