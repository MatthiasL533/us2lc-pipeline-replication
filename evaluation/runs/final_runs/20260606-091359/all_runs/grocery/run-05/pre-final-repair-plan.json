              "kind": "Object",
              "entityRef": "MyFirstModule.SalaryStatement"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Notification",
            "outputVariableName": "Notification_New"
          },
          {
            "type": "showMessage",
            "message": "Salary statement sent to employee."
          }
        ]
      },
      {
        "name": "AutomatePaymentSystem",
        "parameters": [
          {
            "name": "Employee",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Employee"
            }
          },
          {
            "name": "Payment",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Payment"
            }
          }
        ],
        "actions": [
          {
            "type": "showMessage",
            "message": "Payment system automated for employee."
          }
        ]
      },
      {
        "name": "OutsourcePaymentProcess",
        "parameters": [
          {
            "name": "Employee",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Employee"
            }
          },
          {
            "name": "OutsourcedPaymentProcess",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.OutsourcedPaymentProcess"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "OutsourcedPaymentProcess",
            "outputVariableName": "OutsourcedPaymentProcess_New"
          },
          {
            "type": "showMessage",
            "message": "Payment process outsourced for employee."
          }
        ]
      },
      {
        "name": "VerifyWorkHours",
        "parameters": [
          {
            "name": "Employee",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Employee"
            }
          },
          {
            "name": "WorkHour",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.WorkHour"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "WorkHour",
            "outputVariableName": "WorkHour_List"
          },
          {
            "type": "showMessage",
            "message": "Total work hours verified for employee."
          }
        ]
      },
