{
  "pages": {
    "specs": [
      {
        "name": "home",
        "layout": "Blank",
        "widgets": [
          {
            "type": "Text",
            "caption": "Welcome to MyFirstModule"
          },
          {
            "type": "Button",
            "caption": "View Employee Schedule",
            "onClick": {
              "type": "nanoflow",
              "nanoflow": "GetEmployeeSchedule"
            }
          },
          {
            "type": "Button",
            "caption": "File a Complaint",
            "onClick": {
              "type": "page",
              "page": "complaintNewEdit"
            }
          }
        ],
        "content": []
      },
      {
        "name": "employeeOverview",
        "layout": "Table",
        "entity": "Employee",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "Contract"
              },
              {
                "attribute": "Certificate"
              }
            ]
          }
        ],
        "content": []
      },
      {
        "name": "employeeDetail",
        "layout": "FormHorizontal",
        "entity": "Employee",
        "widgets": [
          {
            "type": "TextInput",
            "attribute": "Contract"
          },
          {
            "type": "TextInput",
            "attribute": "Certificate"
          }
        ],
        "content": []
      },
      {
        "name": "complaintOverview",
        "layout": "Table",
        "entity": "Complaint",
        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "Description"
              },
              {
                "attribute": "Category"
              }
            ]
          }
        ],
        "content": []
      },
      {
        "name": "complaintNewEdit",
        "layout": "FormHorizontal",
