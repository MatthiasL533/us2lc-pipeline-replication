        "widgets": [
          {
            "type": "DataGrid",
            "columns": [
              {
                "attribute": "Amount"
              },
              {
                "attribute": "Frequency"
              }
            ]
          }
        ],
        "content": []
      },
      {
        "name": "paymentNewEdit",
        "layout": "FormHorizontal",
        "entity": "Payment",
        "widgets": [
