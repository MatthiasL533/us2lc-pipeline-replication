  "microflows": {
    "specs": [
      {
        "name": "SubscribeToPremium",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.RegisteredUser"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Subscription",
            "outputVariableName": "Subscription_New"
          },
          {
            "type": "changeObject",
            "targetVariableName": "Subscription_New",
            "changes": [
              {
                "attributeRef": "startDate",
                "valueExpression": "[%CurrentDateTime%]"
              },
              {
                "attributeRef": "Price",
                "valueExpression": "9.99"
              },
              {
                "attributeRef": "cancellationDate",
                "valueExpression": "false"
              },
              {
                "attributeRef": "autoRenew",
                "valueExpression": "true"
              },
              {
                "attributeRef": "Status",
                "valueExpression": "'active'"
              }
            ]
          }
        ]
      },
      {
        "name": "UpdatePaymentMethod",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.PremiumUser"
            }
          },
          {
            "name": "paymentDetails",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "PaymentMethod",
            "outputVariableName": "PaymentMethod_New"
          },
          {
            "type": "changeObject",
            "targetVariableName": "PaymentMethod_New",
            "changes": [
              {
                "attributeRef": "paymentDetails",
                "valueExpression": "$paymentDetails"
              },
              {
                "attributeRef": "PaymentType",
                "valueExpression": "'creditCard'"
              },
              {
                "attributeRef": "paymentMethodName",
                "valueExpression": "'Visa'"
              }
            ]
          }
        ]
      },
      {
        "name": "GetHistoricUserPayments",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.RegisteredUser"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "HistoricUserPayments",
            "constraints": [
              {
                "attribute": "PaymentDate",
                "operator": "greaterThan",
                "value": "subtractDays(now, 30)"
              }
            ],
            "outputVariableName": "HistoricUserPayments_List"
          },
          {
            "type": "returnValue",
            "value": "$retrieveList"
          }
        ]
      },
      {
        "name": "GetSubscriptionStatus",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.PremiumUser"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "constraints": [
              {
                "attribute": "Status",
                "operator": "equals",
                "value": "active"
              }
            ],
            "outputVariableName": "Subscription_Object"
          },
          {
            "type": "returnValue",
            "value": "$retrieveObject"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckAutoRenewStatus",
        "parameters": [
          {
            "name": "subscription",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.Subscription"
            }
          }
        ],
        "actions": [
          {
            "type": "decision",
            "conditionExpression": "$subscription.autoRenew == true",
            "trueActions": [],
            "falseActions": []
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
}