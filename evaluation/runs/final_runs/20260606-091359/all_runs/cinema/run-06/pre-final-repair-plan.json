  "microflows": {
    "specs": [
      {
        "name": "SubscribeToPremium",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.RegisteredUser"
            }
          },
          {
            "name": "paymentMethod",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.PaymentMethod"
            }
          }
        ],
        "actions": [
          {
            "type": "createObject",
            "entity": "Subscription",
            "outputVariableName": "Subscription_New"
          }
        ]
      },
      {
        "name": "GetHistoricUserPayments",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.RegisteredUser"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "HistoricUserPayments",
            "outputVariableName": "HistoricUserPayments_List"
          },
          {
            "type": "returnValue",
            "value": "= $HistoricUserPayments"
          }
        ]
      },
      {
        "name": "GetSubscriptionStatus",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.PremiumUser"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "outputVariableName": "Subscription_Object"
          },
          {
            "type": "returnValue",
            "value": "= $Subscription.subscriptionStatus"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "CheckAutomatedRenewalStatus",
        "parameters": [
          {
            "name": "user",
            "type": {
              "kind": "Object",
              "entityRef": "MyFirstModule.PremiumUser"
            }
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Subscription",
            "outputVariableName": "Subscription_Object"
          },
          {
            "type": "decision",
            "trueActions": [
              {
                "type": "showMessage",
                "message": "Automated renewal is enabled"
              }
            ],
            "falseActions": [
              {
                "type": "showMessage",
                "message": "Automated renewal is disabled"
              }
            ],
            "conditionExpression": "= $Subscription_Object.renewalStatus = true"
          }
        ]
      },
      {
        "name": "GetMovieShowtimes",
        "parameters": [
          {
            "name": "movieTitle",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "Showing",
            "outputVariableName": "Showing_List"
          },
          {
            "type": "returnValue",
            "value": "= $Showings"
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
