  },
  "microflows": {
    "specs": [
      {
        "name": "MatchStudentWithTutor",
        "parameters": [
          {
            "name": "studentId",
            "type": "Integer"
          },
          {
            "name": "subjectName",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "Tutor",
            "constraints": [
              {
                "attribute": "Subject",
                "operator": "equals",
                "value": "$subjectName"
              },
              {
                "attribute": "Availability",
                "operator": "contains",
                "value": "$studentId"
              }
            ],
            "outputVariableName": "Tutor_List"
          }
        ]
      },
      {
        "name": "SendSessionNotificationToStudent",
        "parameters": [
          {
            "name": "sessionId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Session",
            "constraints": [
              {
                "attribute": "id",
                "operator": "equals",
                "value": "$sessionId"
              }
            ],
            "outputVariableName": "Session_Object"
          },
          {
            "type": "createObject",
            "entity": "Notification",
            "outputVariableName": "Notification_New"
          },
          {
            "type": "showMessage",
            "message": "Notification sent to student"
          }
        ]
      },
      {
        "name": "UpdateTutorNoShowRate",
        "parameters": [
          {
            "name": "tutorId",
            "type": "Integer"
          },
          {
            "name": "noShowRateValue",
            "type": "Decimal"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Tutor",
            "constraints": [
              {
                "attribute": "id",
                "operator": "equals",
                "value": "$tutorId"
              }
            ],
            "outputVariableName": "Tutor_Object"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "GetTutorAvailability",
        "parameters": [
          {
            "name": "tutorId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Tutor",
            "constraints": [
              {
                "attribute": "id",
                "operator": "equals",
                "value": "$tutorId"
              }
            ],
            "outputVariableName": "Tutor_Object"
          },
          {
            "type": "returnValue",
            "value": "@Tutor/Availability"
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
