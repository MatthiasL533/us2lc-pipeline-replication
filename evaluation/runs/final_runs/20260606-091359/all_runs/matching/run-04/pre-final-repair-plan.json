  "microflows": {
    "specs": [
      {
        "name": "MatchStudentWithTutor",
        "parameters": [
          {
            "name": "studentId",
            "type": "Integer"
          },
          {
            "name": "subjectName",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveList",
            "entity": "Tutor",
            "constraints": [
              {
                "attribute": "TeachingSubject",
                "operator": "equals",
                "value": "$subjectName"
              }
            ],
            "outputVariableName": "Tutor_List"
          }
        ]
      },
      {
        "name": "SendSessionNotificationToStudent",
        "parameters": [
          {
            "name": "sessionId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Session",
            "id": "$sessionId",
            "outputVariableName": "Session_Object"
          },
          {
            "type": "showMessage",
            "message": "$notificationMessage"
          }
        ]
      },
      {
        "name": "UpdateTutorNoShowRate",
        "parameters": [
          {
            "name": "tutorId",
            "type": "Integer"
          },
          {
            "name": "noShowReason",
            "type": "String"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Tutor",
            "id": "$tutorId",
            "outputVariableName": "Tutor_Object"
          },
          {
            "type": "commitObject",
            "variableName": "Tutor_Object"
          }
        ]
      }
    ]
  },
  "nanoflows": {
    "specs": [
      {
        "name": "GetTutorAvailability",
        "parameters": [
          {
            "name": "tutorId",
            "type": "Integer"
          }
        ],
        "actions": [
          {
            "type": "retrieveObject",
            "entity": "Tutor",
            "id": "$tutorId",
            "outputVariableName": "Tutor_Object"
          },
          {
            "type": "returnValue",
            "value": "$tutor.Availability"
          }
        ]
      }
    ]
  },
  "workflows": {
    "specs": []
  }
