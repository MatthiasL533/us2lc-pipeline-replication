digraph process_visualizer {
  t0 [label="Brewery: log in"];
  t1 [label="Brewery, Hospitality business, or Beer2Beer (B2B) management user: log in and be redirected to my personalized homepage so that i can access platform functionalities relevant to my role"];
  t2 [label="Hospitality business: log in and be redirected to my personalized homepage so that i can access platform functionalities relevant to my role"];
  t3 [label="Beer2Beer management user: create proposals for brewery requests so that i can send tailored offers to breweries"];
  t4 [label="Brewery or Hospitality business: create an account so that i can access and use the Beer 2 Beer platform"];
  t5 [label="Brewery: create a product so that i can offer a product for sale on the beer 2 beer platform"];
  t6 [label="Hospitality business: request a sales proposal"];
  t7 [label="beer2beer management user: browse within a catalogue of the beers"];
  t8 [label="hospitality business: create recurring orders based on an order template so that i can schedule multiple deliveries automatically over a set period"];
  t9 [label="Brewery: create order templates that allow i to reorder my product assortment with a single click"];
  t10 [label="beer2beer management user: create a beer order at beer2beer so that i can receive the beers for my business from multiple breweries"];
}
